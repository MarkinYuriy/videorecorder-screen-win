<Window x:Class="VideoRecorderScreen.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings_Title}"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style x:Key="GroupStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10,6,10,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,8,4"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Files -->
        <GroupBox Header="{DynamicResource Settings_GroupFiles}" Style="{StaticResource GroupStyle}">
            <StackPanel>
                <CheckBox x:Name="ChkAutoFormat" Content="{DynamicResource Settings_AutoFormat}"
                          FontWeight="Normal" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource Settings_Folder}" Style="{StaticResource FieldLabel}"/>
                    <TextBox  Grid.Column="1" x:Name="TxtFolder" FontWeight="Normal" VerticalContentAlignment="Center" Height="26"/>
                    <Button   Grid.Column="2" Content="…" Width="28" Height="26" Margin="6,0,0,0" Click="BrowseFolder_Click"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Recording -->
        <GroupBox Header="{DynamicResource Settings_GroupRecording}" Style="{StaticResource GroupStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource Settings_DefaultFps}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbFps" Width="80" FontWeight="Normal" VerticalContentAlignment="Center" Height="26">
                        <ComboBoxItem>5</ComboBoxItem>
                        <ComboBoxItem>10</ComboBoxItem>
                        <ComboBoxItem>15</ComboBoxItem>
                        <ComboBoxItem>20</ComboBoxItem>
                        <ComboBoxItem>30</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="ChkCaptureCursor" Content="{DynamicResource Settings_CaptureCursor}"
                          FontWeight="Normal" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource Settings_Countdown}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbCountdown" Width="70" FontWeight="Normal"
                              VerticalContentAlignment="Center" Height="26">
                        <ComboBoxItem Tag="0">0</ComboBoxItem>
                        <ComboBoxItem Tag="1">1</ComboBoxItem>
                        <ComboBoxItem Tag="2">2</ComboBoxItem>
                        <ComboBoxItem Tag="3">3</ComboBoxItem>
                        <ComboBoxItem Tag="5">5</ComboBoxItem>
                        <ComboBoxItem Tag="10">10</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Text="{DynamicResource Settings_CountdownSec}"
                               VerticalAlignment="Center" Margin="6,0,0,0" FontWeight="Normal"/>
                </StackPanel>
                <TextBlock Text="{DynamicResource Settings_VideoQuality}" FontWeight="Normal" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <RadioButton x:Name="RbLow"    Content="{DynamicResource Settings_QualityLow}"    GroupName="Quality" Margin="0,0,12,0" FontWeight="Normal" Tag="1000" Checked="Quality_Checked"/>
                    <RadioButton x:Name="RbMedium" Content="{DynamicResource Settings_QualityMedium}" GroupName="Quality" Margin="0,0,12,0" FontWeight="Normal" Tag="4000" Checked="Quality_Checked"/>
                    <RadioButton x:Name="RbHigh"   Content="{DynamicResource Settings_QualityHigh}"   GroupName="Quality" Margin="0,0,12,0" FontWeight="Normal" Tag="8000" Checked="Quality_Checked"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Settings_ManualBitrate}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtBitrate" Width="90" Height="26" FontWeight="Normal"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="Bitrate_PreviewInput"
                             TextChanged="Bitrate_TextChanged"/>
                    <TextBlock x:Name="BitrateError" Text="{DynamicResource Settings_BitrateRange}" Foreground="Red"
                               Visibility="Collapsed" VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="Normal"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Control -->
        <GroupBox Header="{DynamicResource Settings_GroupControl}" Style="{StaticResource GroupStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="{DynamicResource Settings_Hotkey}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtHotkey" Width="160" Height="26" FontWeight="Normal"
                             VerticalContentAlignment="Center"
                             PreviewKeyDown="Hotkey_PreviewKeyDown"
                             GotFocus="Hotkey_GotFocus" LostFocus="Hotkey_LostFocus"/>
                    <TextBlock x:Name="HotkeyError" Foreground="Red" Visibility="Collapsed"
                               VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="Normal"/>
                </StackPanel>
                <CheckBox x:Name="ChkLaunchWithWindows" Content="{DynamicResource Settings_LaunchWithWindows}"
                          FontWeight="Normal" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Settings_Language}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbLanguage" Width="200" Height="26" FontWeight="Normal"
                              VerticalContentAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Flag}" FontFamily="Segoe UI Emoji"
                                               FontSize="15" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="{DynamicResource Btn_Save}"   Width="100" Height="28" Margin="0,0,8,0"
                    IsDefault="True" Click="Save_Click"/>
            <Button Content="{DynamicResource Btn_Cancel}" Width="80"  Height="28"
                    IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
