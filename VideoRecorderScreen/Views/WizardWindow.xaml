<Window x:Class="VideoRecorderScreen.Views.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая запись"
        Width="420" Height="290"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step indicator -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,20">
            <Ellipse x:Name="Dot1" Width="12" Height="12" Fill="#4FC3F7"/>
            <Rectangle Width="50" Height="2" Fill="#CCCCCC"
                       VerticalAlignment="Center" Margin="6,0"/>
            <Ellipse x:Name="Dot2" Width="12" Height="12" Fill="#CCCCCC"/>
        </StackPanel>

        <!-- Шаг 2: Настройки записи -->
        <StackPanel x:Name="Step2Panel" Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Настройки записи"
                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,18"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="FPS:" Width="130" VerticalAlignment="Center"/>
                <RadioButton x:Name="Fps5"  Content="5"  GroupName="FPS" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <RadioButton x:Name="Fps10" Content="10" GroupName="FPS" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <RadioButton x:Name="Fps15" Content="15" GroupName="FPS" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <RadioButton x:Name="Fps20" Content="20" GroupName="FPS" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <RadioButton x:Name="Fps30" Content="30" GroupName="FPS" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Микрофон:" Width="130" VerticalAlignment="Center"/>
                <CheckBox x:Name="MicCheck" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Системный звук:" Width="130" VerticalAlignment="Center"/>
                <CheckBox x:Name="SysAudioCheck" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Шаг 3: Сводка -->
        <StackPanel x:Name="Step3Panel" Grid.Row="1"
                    Visibility="Collapsed" VerticalAlignment="Center">
            <TextBlock Text="Готово к записи"
                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,18"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Область:" Foreground="Gray"/>
                <TextBlock x:Name="SummaryRegion" Grid.Row="0" Grid.Column="1"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="FPS:"
                           Foreground="Gray" Margin="0,8,0,0"/>
                <TextBlock x:Name="SummaryFps" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Микрофон:"
                           Foreground="Gray" Margin="0,8,0,0"/>
                <TextBlock x:Name="SummaryMic" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Системный звук:"
                           Foreground="Gray" Margin="0,8,0,0"/>
                <TextBlock x:Name="SummaryAudio" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"/>
            </Grid>
        </StackPanel>

        <!-- Кнопки навигации -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Button x:Name="BackButton" Content="← Назад"
                    HorizontalAlignment="Left" Width="90" Height="30"
                    Visibility="Collapsed" Click="Back_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Width="80" Height="30"
                        Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button x:Name="NextButton" Content="Далее →"
                        Width="130" Height="30" Click="Next_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
