<Window x:Class="VideoRecorderScreen.Views.RecordingTimerPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#CC000000"
        Topmost="True"
        ShowInTaskbar="False"
        Width="190" Height="38"
        ResizeMode="NoResize">
    <Border Padding="10,5">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="RecDot" Width="9" Height="9" Fill="#FF4444"
                     VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="TimerText" Text="00:00"
                       FontSize="14" FontFamily="Consolas"
                       Foreground="White" VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
            <Button x:Name="StopButton"
                    Content="{DynamicResource StopBtn}"
                    Foreground="White"
                    Background="#55333333"
                    BorderBrush="#88666666"
                    BorderThickness="1"
                    Padding="8,2"
                    FontSize="12"
                    Cursor="Hand"
                    Click="Stop_Click"/>
        </StackPanel>
    </Border>
</Window>
