<Window x:Class="VideoRecorderScreen.Views.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="True">
    <Canvas x:Name="Root">

        <!-- Рамка вокруг области записи -->
        <Rectangle x:Name="RegionBorder"
                   Stroke="#FF3333"
                   StrokeThickness="3"
                   Fill="Transparent"
                   IsHitTestVisible="False"/>

        <!-- Панель управления: точка + таймер + стоп -->
        <Border x:Name="ControlPanel"
                Background="#CC000000"
                CornerRadius="5"
                Padding="10,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="RecDot"
                         Width="12" Height="12"
                         Fill="#FF3333"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBlock x:Name="TimerLabel"
                           Foreground="White"
                           FontSize="14"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <Button x:Name="StopBtn"
                        Content="■  Стоп"
                        Foreground="White"
                        Background="#AA333333"
                        BorderBrush="#666666"
                        BorderThickness="1"
                        Padding="10,3"
                        Cursor="Hand"
                        Click="Stop_Click"/>
            </StackPanel>
        </Border>

    </Canvas>
</Window>
