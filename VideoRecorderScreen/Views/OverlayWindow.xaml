<Window x:Class="VideoRecorderScreen.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Focusable="True"
        Cursor="Cross">
    <Canvas x:Name="Root"
            Background="Transparent"
            MouseDown="Root_MouseDown"
            MouseMove="Root_MouseMove"
            MouseUp="Root_MouseUp">
        <Path x:Name="DarkOverlay"
              Fill="#A0000000"
              IsHitTestVisible="False"/>
        <Rectangle x:Name="SelectionBorder"
                   Stroke="#4FC3F7"
                   StrokeThickness="2"
                   Fill="Transparent"
                   IsHitTestVisible="False"/>
        <TextBlock x:Name="SizeLabel"
                   Foreground="White"
                   FontSize="11"
                   FontFamily="Consolas"
                   Background="#80000000"
                   Padding="4,2"
                   IsHitTestVisible="False"/>
        <TextBlock x:Name="HintLabel"
                   Text="Перетащите для выбора региона  •  Enter — подтвердить  •  Esc / ПКМ — отмена"
                   Foreground="White"
                   FontSize="13"
                   Background="#80000000"
                   Padding="10,5"
                   IsHitTestVisible="False"/>
    </Canvas>
</Window>
